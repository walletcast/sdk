{
  "name": "@walletcast/sdk",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./p2p": {
      "types": "./dist/p2p.d.ts",
      "import": "./dist/p2p.js",
      "require": "./dist/p2p.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/p2p.ts --format cjs,esm --dts && tsup --config tsup.browser.config.ts",
    "build:browser": "tsup --config tsup.browser.config.ts",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "files": ["dist"],
  "dependencies": {
    "@walletcast/types": "workspace:*",
    "@walletcast/crypto": "workspace:*",
    "@walletcast/uri": "workspace:*",
    "@walletcast/nostr-signaling": "workspace:*",
    "@walletcast/libp2p-signaling": "workspace:*",
    "@walletcast/webrtc": "workspace:*",
    "@walletcast/broker": "workspace:*",
    "@walletcast/provider": "workspace:*",
    "@walletcast/qr": "workspace:*",
    "@walletcast/deep-link": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
