{
  "name": "@walletcast/deep-link",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts && node scripts/build-connector.mjs",
    "build:lib": "tsup src/index.ts --format cjs,esm --dts",
    "build:connector": "node scripts/build-connector.mjs",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@walletcast/types": "workspace:*",
    "@walletcast/nostr-signaling": "workspace:*",
    "@walletcast/provider": "workspace:*",
    "@walletcast/crypto": "workspace:*",
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "nostr-tools": "^2.10.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "tsup": "^8.4.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
