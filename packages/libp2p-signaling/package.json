{
  "name": "@walletcast/libp2p-signaling",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build:wasm": "cd rust && wasm-pack build --target web --out-dir ../wasm",
    "build:ts": "tsup src/index.ts --format cjs,esm --dts",
    "build": "npm run build:ts",
    "test": "vitest run",
    "clean": "rm -rf dist wasm"
  },
  "files": ["dist", "wasm"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@walletcast/types": "workspace:*",
    "@walletcast/crypto": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
